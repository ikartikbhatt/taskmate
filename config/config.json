{
  "userRoles": ["user", "admin"],
  "regex": {
    "emailRegex": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$",
    "passRegex": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&])[A-Za-z\\d@$!%*?&]{8,}$",
    "teamNameRegex": "^[A-Za-z _-]+$",
    "teamKeyRegex": "^[A-F0-9]{12}$"
  },
  "acceptTeamKey": ["Y", "N"]
}
